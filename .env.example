# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Connection string for PostgreSQL. The default below matches docker-compose.yml
# so `docker compose up -d db` + this value works out of the box.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/reviewdash?schema=public"

# -----------------------------------------------------------------------------
# Review source
# -----------------------------------------------------------------------------
# Which upstream source to ingest from. Defaults to "mock" so the app runs from a
# clean clone with no external credentials.
#   mock   -> realistic fixture data that simulates the messy realities of a real
#             upstream (latency, flakiness, rate limits, inconsistent fields).
#   amazon -> real Amazon reviews via a scraping-API provider (requires a key,
#             see AMAZON_API_KEY). Falls back to "mock" if the key is missing.
REVIEW_SOURCE="mock"

# API key for the Amazon scraping provider (e.g. Rainforest / ScraperAPI).
# Left blank on purpose — never commit real keys. If empty, the amazon source is
# disabled and ingestion falls back to the mock source.
AMAZON_API_KEY=""

# Base URL used by the dashboard (server component) to call our own REST API.
# In most local setups the default is correct.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
